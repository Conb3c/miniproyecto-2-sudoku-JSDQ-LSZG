                <GridPane fx:id="sudokuGrid" hgap="0" maxHeight="360" maxWidth="360" prefHeight="360" prefWidth="360" style="-fx-background-color: white;" vgap="0">
                    <columnConstraints>
                        <ColumnConstraints fillWidth="true" maxWidth="60" minWidth="60" prefWidth="60" />
                        <ColumnConstraints fillWidth="true" maxWidth="60" minWidth="60" prefWidth="60" />
                        <ColumnConstraints fillWidth="true" maxWidth="60" minWidth="60" prefWidth="60" />
                        <ColumnConstraints fillWidth="true" maxWidth="60" minWidth="60" prefWidth="60" />
                        <ColumnConstraints fillWidth="true" maxWidth="60" minWidth="60" prefWidth="60" />
                        <ColumnConstraints fillWidth="true" maxWidth="60" minWidth="60" prefWidth="60" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints fillHeight="true" maxHeight="60" minHeight="60" prefHeight="60" />
                        <RowConstraints fillHeight="true" maxHeight="60" minHeight="60" prefHeight="60" />
                        <RowConstraints fillHeight="true" maxHeight="60" minHeight="60" prefHeight="60" />
                        <RowConstraints fillHeight="true" maxHeight="60" minHeight="60" prefHeight="60" />
                        <RowConstraints maxHeight="60.0" minHeight="60.0" prefHeight="60.0" />
                        <RowConstraints fillHeight="true" maxHeight="60" minHeight="60" prefHeight="60" />
                    </rowConstraints>

                    <!--
                        CELDAS FIJAS (dadas por el puzzle): editable="false", texto negro/azul
                        CELDAS VACÍAS (el usuario las llena): editable="true", texto azul
                        El estilo base incluye borde derecho/inferior fino.
                        Columnas 2 y 5 tienen borde derecho más grueso (separador de caja 3x2 → aquí 2x3).
                        Filas 1 y 3 tienen borde inferior más grueso.
                        Ajusta editable="true/false" según tu lógica de puzzle.
                    -->

                    <!-- ESTILOS REUTILIZABLES (definidos como constantes de referencia en comentarios):
                         FIJA   : -fx-background-color: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-alignment: center; -fx-border-color: transparent; -fx-background-radius: 0;
                         EDITABLE: igual pero -fx-text-fill: #2C5F8A; -fx-background-color: white;
                         ERROR  : -fx-background-color: #FDECEA; -fx-text-fill: #E05252;
                         SELECTED: -fx-background-color: #D6E8F7;
                    -->


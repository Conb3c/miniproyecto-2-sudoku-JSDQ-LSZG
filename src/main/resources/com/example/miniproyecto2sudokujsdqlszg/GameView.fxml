<BorderPane prefHeight="560" prefWidth="900" style="-fx-background-color: #F5F5F0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.GameController">

    <!-- ===== TOP: Header ===== -->
    <top>
        <VBox alignment="CENTER" spacing="2">
            <padding><Insets bottom="6.0" top="40.0" /></padding>
            <Label alignment="CENTER" style="-fx-font-family: 'Georgia'; -fx-font-size: 45px; -fx-font-weight: bold; -fx-text-fill: #2C5F8A;" text="SUDOKU" textAlignment="CENTER">
                <font>
                    <Font name="Century Schoolbook" size="24.0" />
                </font>
                <padding>
                    <Insets right="20.0" />
                </padding></Label>
        </VBox>
    </top>

    <!-- ===== CENTER ===== -->
    <center>
        <HBox alignment="CENTER" prefHeight="435.0" prefWidth="900.0" spacing="40">
            <padding><Insets bottom="20.0" left="60.0" right="40.0" top="10.0" /></padding>

            <!-- LEFT PANEL -->
            <VBox alignment="TOP_CENTER" prefWidth="110" spacing="16">
                <VBox alignment="CENTER_LEFT" prefWidth="100" spacing="2" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <padding><Insets bottom="10" left="14" right="14" top="10" /></padding>
                    <Label style="-fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-font-weight: bold; -fx-letter-spacing: 1.5; -fx-text-fill: #AAAAAA;" text="TIMER" />
                    <Label fx:id="timerLabel" style="-fx-font-family: 'Arial'; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C5F8A;" text="00:00" />
                    <VBox.margin>
                        <Insets top="15.0" />
                    </VBox.margin>
                </VBox>
                <VBox alignment="CENTER_LEFT" prefWidth="100" spacing="2" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <padding><Insets bottom="10" left="14" right="14" top="10" /></padding>
                    <Label style="-fx-font-family: 'Arial'; -fx-font-size: 9px; -fx-font-weight: bold; -fx-letter-spacing: 1.5; -fx-text-fill: #AAAAAA;" text="ERRORS" />
                    <Label fx:id="errorsLabel" style="-fx-font-family: 'Arial'; -fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #E05252;" text="00/03" />
                </VBox>
            </VBox>


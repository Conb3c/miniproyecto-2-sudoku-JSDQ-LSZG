                    <TextField fx:id="cell_0_2" editable="false" maxHeight="60" maxWidth="60" prefHeight="60" prefWidth="60" style="-fx-background-color: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1A2E; -fx-alignment: center; -fx-border-color: #D0D8E4 #2C5F8A #D0D8E4 transparent; -fx-border-width: 0 2 1 0; -fx-background-radius: 0; -fx-border-radius: 0;" text="3" GridPane.columnIndex="2" GridPane.rowIndex="0" />
